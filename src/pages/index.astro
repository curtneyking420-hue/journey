---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
</head>

<body>
  <Header />

  <main>
    <h1>Journey to Greatness</h1>

    <p>Welcome to my digital journal.</p>

    <p>
      My name is Curtney King. I am a New York City asphalt worker,
      creator, builder, and lifelong learner.
    </p>

    <p>
      This website documents ideas, books, systems, and experiments
      focused on history, science, technology, finance, and personal growth.
    </p>

    <p>Current projects include:</p>

    <ul>
      <li>There's Two Boats</li>
      <li>Universal Mechanics</li>
      <li>NYC Pavement Digital Twin</li>
      <li>AI Comic-to-Movie System</li>
    </ul>

    <p><strong>We Don't Work The Same.</strong></p>
  </main>

  <Footer />
</body>
</html>
